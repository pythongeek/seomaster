# SEOMaster - Vercel Environment Variables

# ─── AI (MiniMax M2.7 via OpenRouter/Hermes) ─────────────────────────────
ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
ANTHROPIC_AUTH_TOKEN=X-cp-your-token
ANTHROPIC_MODEL=MiniMax-M2.7
OPENROUTER_API_KEY=k-cp-your-token
OPENROUTER_BASE_URL=https://api.minimax.io/anthropic

# ─── Database: Neon PostgreSQL (free serverless) ────────────────────────────
# Sign up at https://neon.tech — free tier: 0.5GB storage, 5 projects
DATABASE_URL=postgresql://user:password@ep-xxx-xxx-123456.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Google Search Console — Service Account ───────────────────────────────
# Create a Service Account in Google Cloud Console:
# 1. Go to https://console.cloud.google.com → IAM → Service Accounts
# 2. Create a service account and download the JSON key
# 3. Share your GSC property with the service account email
# 4. Add these env vars:
GSC_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# Paste the private_key value with real newlines (not \n):
GSC_SERVICE_ACCOUNT_KEY=-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n

# ─── Redis / BullMQ Broker ─────────────────────────────────────────────────
# Option A: Railway Redis (recommended — free tier: 500 hours/month)
#   Create at https://railway.app → New Project → Add Redis
#   Public Networking must be enabled in Railway Redis Settings → Networking
#   Connection format: redis://default:PASSWORD@trolley.proxy.rlwy.net:PORT
# REDIS_URL=redis://default:your-password@trolley.proxy.rlwy.net:your-port

# Option B: Local Redis (Docker)
#   docker run -d --name seomaster-redis -p 6379:6379 redis:7-alpine
# REDIS_URL=redis://localhost:6379

# ─── Job Queue Settings ─────────────────────────────────────────────────────
# Secret for cron-jobs.org auth — generate: openssl rand -hex 32
CRON_SECRET=your-secure-random-string
WORKER_CONCURRENCY=2

# ─── Vercel (auto-populated) ──────────────────────────────────────────────
# VERCEL_URL=https://your-app.vercel.app
# NODE_ENV=production
